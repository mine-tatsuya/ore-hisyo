// Prismaの設定ファイル
// ここでDBのテーブル構造（スキーマ）を定義します

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// NextAuth.js が必要とするテーブル群
// （NextAuth が自動的に読み書きするため、名前を変えてはいけない）
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // リレーション（1人のUserが複数のAccountやTaskを持てる）
  accounts       Account[]
  sessions       Session[]
  settings       Settings?
  tasks          Task[]
  logs           Log[]
  recurringTasks RecurringTask[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  // Googleのトークンを保存する（@db.Text は長い文字列対応）
  refresh_token             String? @db.Text
  access_token              String? @db.Text
  expires_at                Int?
  token_type                String?
  scope                     String?
  id_token                  String? @db.Text
  session_state             String?
  // Google が返す追加フィールド（リフレッシュトークンの有効期限）
  refresh_token_expires_in  Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// アプリ固有のテーブル
// ============================================================

// ユーザーの生活リズムや AI 指示設定
model Settings {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 生活リズム（HH:MM 形式で保存）
  wakeUpTime     String  @default("07:00")
  bedTime        String  @default("23:00")
  lunchStart     String  @default("12:00")
  lunchEnd       String  @default("13:00")
  focusTimeStart String?
  focusTimeEnd   String?

  // AI の性格設定
  aiPersonality  AiPersonality @default(BALANCED)
  aiCustomPrompt String?       @db.Text

  // カレンダーへの反映モード
  calendarMode CalendarMode @default(MANUAL)

  // Cron 設定（calendarMode = AUTO のときのみ使用）
  cronTime         String @default("12:00")
  // 自動実行時刻（JST, HH:00 形式。例: "07:00"）
  // vercel.json を毎時実行にして、この時刻に一致したユーザーだけ処理する

  cronTargetOffset Int    @default(1)
  // 何日後のスケジュールを生成するか（0=当日, 1=翌日, 2=2日後）

  // 居住地（天気予報取得に使用。都道府県名で入力：例 "熊本県"）
  location String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// タスク（ユーザーが登録する課題・予定）
model Task {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // タスクの基本情報
  title            String
  description      String?  @db.Text
  deadline         DateTime?
  estimatedMinutes Int
  priority         Priority @default(MEDIUM)

  // 進捗状態
  status      TaskStatus @default(PENDING)
  progressPct Int        @default(0)

  // AI がカレンダーに書き込んだときの Google Event ID
  calendarEventId String?

  // AI がスケジュールを割り当てた時間帯
  scheduledStart DateTime?
  scheduledEnd   DateTime?

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs Log[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, deadline])
}

// 定期タスク（毎日・毎週・N日ごと・毎月 繰り返すタスク）
// 家事・運動など「期日はないが定期的にやること」を管理し、
// Gemini のスケジュール生成に組み込む
model RecurringTask {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title            String
  description      String?  @db.Text   // Gemini への補足メモ兼用
  estimatedMinutes Int
  priority         Priority @default(MEDIUM)
  isActive         Boolean  @default(true)

  // 繰り返しパターン
  recurrenceType   RecurrenceType
  daysOfWeek       String?  // WEEKLY 時: JSON配列 "[1,3,5]" (1=月〜7=日)
  intervalDays     Int?     // INTERVAL 時: 何日ごとか
  dayOfMonth       Int?     // MONTHLY 時: 何日か (1-31)
  startDate        DateTime @default(now()) // INTERVAL の基準日

  // 希望時間帯
  preferredTimeType  PreferredTimeType?  // MORNING/NOON/EVENING/SPECIFIC
  preferredStartTime String?             // SPECIFIC 時: "HH:MM"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// 計画と実績のログ（AIが学習する材料）
model Log {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  createdAt DateTime @default(now())

  // AI が割り当てた計画値
  plannedStart   DateTime
  plannedEnd     DateTime
  plannedMinutes Int

  // ユーザーが報告した実績値
  actualMinutes     Int?
  actualProgressPct Int?

  // 精度（actualMinutes / plannedMinutes）: 1.0 = ぴったり、1.3 = 30%超過
  accuracyRatio Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taskId])
}

// ============================================================
// Enum（選択肢の定義）
// ============================================================

enum AiPersonality {
  STRICT   // 厳しめ
  BALANCED // バランス型
  RELAXED  // ゆったり
}

enum CalendarMode {
  AUTO   // Cron で自動反映
  MANUAL // 手動で確認してから反映
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING     // 未着手
  IN_PROGRESS // 進行中
  DONE        // 完了
  CANCELLED   // キャンセル
}

enum RecurrenceType {
  DAILY    // 毎日
  WEEKLY   // 毎週 特定曜日
  INTERVAL // N日ごと
  MONTHLY  // 毎月 特定日
}

enum PreferredTimeType {
  MORNING   // 朝 (6:00-10:00)
  NOON      // 昼 (11:00-14:00)
  EVENING   // 夜 (18:00-22:00)
  SPECIFIC  // 具体的な時刻 (preferredStartTime を使用)
}
